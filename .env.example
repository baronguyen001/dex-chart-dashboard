# dexscope configuration — NO API KEYS NEEDED.
# GeckoTerminal (OHLCV) and DexScreener (live price) are both keyless public APIs.
# All values below are optional; uncomment to override the defaults.

# DEXSCOPE_HOST=127.0.0.1
# DEXSCOPE_PORT=5066
# DEXSCOPE_WATCHLIST=watchlist.json
# DEXSCOPE_CACHE_DIR=data/ohlc_cache
# DEXSCOPE_LIVE_CACHE=data/live_prices_cache.json
# DEXSCOPE_CACHE_TTL_SEC=900
# DEXSCOPE_RATE_MIN_INTERVAL=2.2
